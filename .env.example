# Copy this file to `.env.local` for local development.
# Vite will load `.env.local` automatically.

# --- Database (required for remote sync API) ---
# Provide ONE of these Postgres connection strings.
# If you use Neon/Vercel Postgres, `POSTGRES_URL` is the most common.
POSTGRES_URL="postgres://USER:PASSWORD@HOST:5432/DB?sslmode=require"
POSTGRES_PRISMA_URL=""
DATABASE_URL=""

# --- Translation (optional; used by /api/translate) ---
# Provider selection:
# - "google": Google Cloud Translation API v2 (requires billing + API key)
# - "libre": LibreTranslate-compatible endpoint
# If not set, the app prefers Google when GOOGLE_TRANSLATE_API_KEY is present.
TRANSLATE_PROVIDER="google"

# --- Google Cloud Translate (recommended) ---
# Create an API key in Google Cloud Console and enable the Cloud Translation API.
GOOGLE_TRANSLATE_API_KEY=""

# --- LibreTranslate (fallback / self-host) ---
# Defaults to: https://de.libretranslate.com/translate
TRANSLATE_API_URL="https://de.libretranslate.com/translate"
# Set only if your provider requires an API key
TRANSLATE_API_KEY=""
